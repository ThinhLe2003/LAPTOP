@model IEnumerable<LAPTOP.Models.ChiTietSanPham>

@{
    ViewData["Title"] = "Danh sách Chi Tiết Sản Phẩm";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Thêm chi tiết sản phẩm mới</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Mã SP</th>
            <th>Tên SP</th>
            <th>CPU</th>
            <th>RAM</th>
            <th>VGA</th>
            <th>Màn Hình</th>
            <th>HĐH</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaSp</td>
                <td>@item.MaSpNavigation?.TenSp</td>
                <td>@item.Cpu</td>
                <td>@item.Ram</td>
                <td>@item.Vga</td>
                <td>@item.ManHinh</td>
                <td>@item.HeDieuHanh</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.MaSp" class="btn btn-primary btn-sm">Sửa</a>
                    <a asp-action="Details" asp-route-id="@item.MaSp" class="btn btn-info btn-sm">Chi tiết</a>
                    <a asp-action="Delete" asp-route-id="@item.MaSp" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
