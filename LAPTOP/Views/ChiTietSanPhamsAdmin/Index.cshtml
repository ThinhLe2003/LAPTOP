@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Danh sách Chi Tiết Sản Phẩm";
}

<h2 class="mb-3">@ViewData["Title"]</h2>

<p>
    <a href="/ChiTietSanPhamsAdmin/Create" class="btn btn-success">Thêm chi tiết sản phẩm mới</a>
</p>

<table class="table table-striped table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Mã SP</th>
            <th>Tên SP</th>
            <th>CPU</th>
            <th>RAM</th>
            <th>VGA</th>
            <th>Màn Hình</th>
            <th>HĐH</th>
            <th>Kích thước</th>
            <th>Màu sắc</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaSp</td>
                <td>@item.TenSp</td>
                <td>@item.Cpu</td>
                <td>@item.Ram</td>
                <td>@item.Vga</td>
                <td>@item.ManHinh</td>
                <td>@item.HeDieuHanh</td>
                <td>@item.KichThuoc</td>
                <td>@item.MauSac</td>
                <td>
                    <a href="/ChiTietSanPhamsAdmin/Edit/@item.MaSp" class="btn btn-primary btn-sm">Sửa</a>
                    <a href="/ChiTietSanPhamsAdmin/Details/@item.MaSp" class="btn btn-info btn-sm">Chi tiết</a>
                    <a href="/ChiTietSanPhamsAdmin/Delete/@item.MaSp" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
