@model LAPTOP.Models.ChiTietSanPham

@{
    ViewData["Title"] = "Xóa Chi Tiết Sản Phẩm";
}

<h2>@ViewData["Title"]</h2>

<h4>Bạn có chắc chắn muốn xóa chi tiết sản phẩm này không?</h4>

<table class="table table-bordered">
    <tr><th>Mã SP</th><td>@Model.MaSp</td></tr>
    <tr><th>Tên SP</th><td>@Model.MaSpNavigation?.TenSp</td></tr>
    <tr><th>CPU</th><td>@Model.Cpu</td></tr>
    <tr><th>RAM</th><td>@Model.Ram</td></tr>
    <tr><th>VGA</th><td>@Model.Vga</td></tr>
    <tr><th>Màn hình</th><td>@Model.ManHinh</td></tr>
</table>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="MaSp" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
