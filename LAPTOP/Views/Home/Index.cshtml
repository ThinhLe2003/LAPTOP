@model IEnumerable<LAPTOP.Models.SanPham>
    @{
    ViewData["Title"] = " LaptopShop - Laptop Chính Hãng Giá Tốt Nhất";

    // 1. Flash Sale: Ưu tiên sản phẩm IsFeatured = true, sau đó là có khuyến mãi
    var flashSaleProducts = Model
        .Where(p => p.IsFeatured)
        .Take(8)
        .ToList();

    // Nếu không đủ hoặc không có IsFeatured, lấy thêm sản phẩm có khuyến mãi
    if (flashSaleProducts.Count < 8)
    {
        var more = Model
            .Where(p => !p.IsFeatured && p.GiaKhuyenMai.HasValue && p.GiaKhuyenMai < p.Gia)
            .Take(8 - flashSaleProducts.Count);
        flashSaleProducts.AddRange(more);
    }

    // Nếu vẫn không đủ → lấy bất kỳ sản phẩm nào
    if (flashSaleProducts.Count < 8)
    {
        var remain = Model
            .Where(p => !flashSaleProducts.Select(x => x.MaSp).Contains(p.MaSp))
            .Take(8 - flashSaleProducts.Count);
        flashSaleProducts.AddRange(remain);
    }

    // 2. Bán chạy & Mới nhất: Vì không có LuotBan/NgayNhap → lấy theo thứ tự MaSp giảm dần (mới thêm sau lên đầu)
    var otherProducts = Model
        .OrderByDescending(p => p.MaSp)
        .Take(16)
        .ToList();

    var bestSelling = otherProducts.Take(8).ToList();
    var newArrivals = otherProducts.Skip(8).Take(8).ToList();
    }

   

    <!-- Hero Banner -->
    <section class="container my-5">
        <div class="row g-0 align-items-center">
            <!-- Sidebar Danh Mục (Desktop only) -->
            <div class="col-lg-2 d-none d-lg-block">
                <div class="bg-light p-4 rounded-3 shadow-sm">
                    <h6 class="fw-bold mb-3 text-uppercase small text-danger">Danh Mục Nổi Bật</h6>
                    <ul class="list-unstyled">
                        <li class="py-2"><a asp-controller="SanPham" asp-action="Index" asp-route-maLoai="1" class="text-dark text-decoration-none"> Laptop Gaming</a></li>
                        <li class="py-2"><a asp-controller="SanPham" asp-action="Index" asp-route-maLoai="2" class="text-dark text-decoration-none"> Laptop Văn Phòng</a></li>
                        <li class="py-2"><a asp-controller="SanPham" asp-action="Index" asp-route-maLoai="3" class="text-dark text-decoration-none"> Laptop Đồ Họa</a></li>
                        <li class="py-2"><a asp-controller="SanPham" asp-action="Index" asp-route-maLoai="4" class="text-dark text-decoration-none"> Laptop Sinh Viên</a></li>
                        <li class="py-2 text-danger fw-bold"><a asp-controller="SanPham" asp-action="Index" asp-route-maLoai="5" class="text-danger text-decoration-none"> MacBook Chính Hãng</a></li>
                        <li class="py-2"><a asp-controller="SanPham" asp-action="Index" class="text-dark text-decoration-none"> Surface & 2-in-1</a></li>
                    </ul>
                </div>
            </div>

            <!-- Banner Chính -->
            <div class="col-lg-10 ps-lg-4">
                <div class="position-relative rounded-4 overflow-hidden shadow-lg" style="height: 520px;">
                    <img src="https://images.unsplash.com/photo-1603302576837-37561b2e2302?w=1600&h=900&fit=crop"
                         class="w-100 h-100" style="object-fit: cover;" alt="Laptop Sale 2025">
                    <div class="position-absolute top-50 start-50 translate-middle text-center text-white px-4">
                        <h1 class="display-3 fw-bold">BLACK FRIDAY 2025</h1>
                        <h2 class="display-5 fw-bold text-warning">GIẢM TỚI 8.000.000₫</h2>
                        <p class="fs-3 mb-4">MacBook M4 • RTX 50 Series • Dell XPS • ASUS ROG</p>
                        <a asp-controller="SanPham" asp-action="Index" class="btn btn-danger btn-lg px-5 py-3 rounded-pill shadow">
                            MUA NGAY
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Flash Sale Section -->
    <section id="flash-sale" class="container my-5">
        <div class="d-flex align-items-end justify-content-between mb-4">
            <div class="d-flex align-items-end">
                <div class="bg-danger text-white px-4 py-2 rounded me-3 fw-bold fs-5">Today's</div>
                <h2 class="fw-bold fs-1 mb-0">Flash Sale</h2>
            </div>
            <div id="countdown-timer" class="d-flex align-items-center fs-4"></div>
        </div>

        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4">
            @foreach (var sp in flashSaleProducts)
        {
            var giaHienThi = sp.GiaKhuyenMai.HasValue && sp.GiaKhuyenMai > 0 ? sp.GiaKhuyenMai.Value : sp.Gia ?? 0;
            var giamGia = sp.GiaKhuyenMai.HasValue && sp.GiaKhuyenMai < sp.Gia
                ? Math.Round((double)((sp.Gia.Value - sp.GiaKhuyenMai.Value) / sp.Gia.Value * 100))
                : 0;

            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-lift position-relative overflow-hidden rounded-3">
                    @if (giamGia > 0)
                    {
                    <span class="position-absolute top-0 start-0 bg-danger text-white px-3 py-1 small fw-bold z-3">
                        -@giamGia%
                    </span>
                    }
                    @if (sp.IsFeatured)
                    {
                    <span class="position-absolute top-0 end-0 bg-warning text-dark px-3 py-1 small fw-bold z-3">
                        HOT
                    </span>
                    }

                    <div class="text-center bg-light p-4">
                        <img src="@sp.HinhAnh" class="img-fluid" style="height: 180px; object-fit: contain;" alt="@sp.TenSp">
                    </div>

                    <div class="card-body text-center d-flex flex-column justify-content-between">
                        <div>
                            <h6 class="fw-bold mb-2" style="height: 50px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                @sp.TenSp
                            </h6>
                            <p class="text-danger fw-bold fs-4 mb-1">
                                @string.Format("{0:N0}", giaHienThi) ₫
                            </p>
                            @if (giamGia > 0)
                            {
                            <p class="text-muted small text-decoration-line-through">
                                @string.Format("{0:N0}", sp.Gia) ₫
                            </p>
                            }
                        </div>

                        <a asp-controller="GioHang" asp-action="AddToCart" asp-route-id="@sp.MaSp"
                           class="btn btn-dark w-100 mt-3 py-3 fw-bold">
                            THÊM VÀO GIỎ
                        </a>
                    </div>
                </div>
            </div>
        }
        </div>

        <div class="text-center mt-5">
            <a asp-controller="SanPham" asp-action="Index" class="btn btn-outline-dark btn-lg px-5">
                XEM TẤT CẢ SẢN PHẨM →
            </a>
        </div>
    </section>

    <!-- Bán Chạy Nhất -->
    <section class="container my-5">
        <h2 class="fw-bold fs-1 mb-4 text-center"> BÁN CHẠY NHẤT THÁNG</h2>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4">
            @foreach (var sp in bestSelling)
        {
            await Html.RenderPartialAsync("_ProductCard", sp);
        }
        </div>
    </section>

    <!-- Sản Phẩm Mới Nhất -->
    <section class="bg-light py-5">
        <div class="container">
            <h2 class="fw-bold fs-1 mb-5 text-center"> SẢN PHẨM MỚI NHẤT</h2>
            <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
                @foreach (var sp in newArrivals)
            {
                await Html.RenderPartialAsync("_ProductCard", sp);
            }
            </div>
        </div>
    </section>

    <!-- Countdown Timer -->
    <script>
        const endTime = new Date();
        endTime.setHours(23, 59, 59, 999);

        const timer = setInterval(() => {
            const now = new Date().getTime();
            const distance = endTime - now;

            if (distance < 0) {
                document.getElementById("countdown-timer").innerHTML = "<span class='text-danger fw-bold fs-3'>ĐÃ HẾT HẠN!</span>";
                clearInterval(timer);
                return;
            }

            const hours = String(Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))).padStart(2, '0');
            const minutes = String(Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60))).padStart(2, '0');
            const seconds = String(Math.floor((distance % (1000 * 60)) / 1000)).padStart(2, '0');

            document.getElementById("countdown-timer").innerHTML = `
                <span class="bg-dark text-white px-3 py-2 rounded">${hours}</span>
                <span class="mx-2 text-muted">:</span>
                <span class="bg-dark text-white px-3 py-2 rounded">${minutes}</span>
                <span class="mx-2 text-muted">:</span>
                <span class="bg-dark text-white px-3 py-2 rounded">${seconds}</span>
            `;
        }, 1000);
    </script>

    <!-- Tạo file Partial để tái sử dụng card (tùy chọn nhưng rất sạch code) -->
    <!-- Đường dẫn: Views/Shared/_ProductCard.cshtml -->
